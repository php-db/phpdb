{
    "extensions": [
        "pdo-sqlite",
        "sqlite3",
        "sqlsrv"
    ],
    "exclude": [
        {
            "php": "8.4",
            "extensions": "sqlsrv"
        },
        {
            "php": "8.5",
            "extensions": "sqlsrv"
        }
    ],
    "additional_checks": [
        {
            "name": "PhpStan",
            "job": {
                "php": "8.2",
                "dependencies": "latest",
                "command": "composer require --dev phpstan/phpstan && vendor/bin/phpstan analyse"
            }
        }
    ]
}