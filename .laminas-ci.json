{
    "extensions": [
        "pdo-sqlite",
        "sqlite3"
    ],
    "ignore_commands": [
        "vendor/bin/phpbench"
    ],
    "additional_checks": [
        {
            "name": "PhpStan",
            "job": {
                "php": "8.2",
                "dependencies": "latest",
                "command": "composer require --dev phpstan/phpstan && vendor/bin/phpstan analyse"
            }
        }
    ]
}